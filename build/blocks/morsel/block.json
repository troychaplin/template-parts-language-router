{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tidbits/morsel",
  "version": "0.1.0",
  "title": "Morsel",
  "category": "text",
  "description": "A single Tidbit post displayed within a Tidbits block.",
  "parent": [
    "tidbits/tidbit"
  ],
  "attributes": {
    "postId": {
      "type": "number",
      "default": 0
    }
  },
  "usesContext": [
    "tidbits/displayMode"
  ],
  "supports": {
    "html": false,
    "reusable": false
  },
  "textdomain": "tidbits",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php"
}