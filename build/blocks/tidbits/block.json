{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tidbits/tidbit",
  "version": "0.1.0",
  "title": "Tidbits",
  "category": "text",
  "keywords": [
    "tidbits",
    "tips",
    "tricks",
    "insights",
    "terms",
    "definitions",
    "glossary",
    "facts",
    "fun facts",
    "quick tips",
    "short insights"
  ],
  "description": "Display hand-picked Tidbit posts in a variety of layouts.",
  "attributes": {
    "displayMode": {
      "type": "string",
      "default": "accordion",
      "enum": [
        "accordion",
        "stacked",
        "columns"
      ]
    }
  },
  "providesContext": {
    "tidbits/displayMode": "displayMode"
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ],
    "layout": {
      "allowEditing": false
    },
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ],
      "padding": true
    }
  },
  "textdomain": "tidbits",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScriptModule": "file:./view.js"
}